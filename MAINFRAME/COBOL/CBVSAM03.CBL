017802       DISPLAY ' FS-EMP-ORDEM       = ' FS-EMP-ORDEM
017803       DISPLAY ' FS-EMP-NAME        = ' FS-EMP-NAME
017804       DISPLAY ' FS-EMP-TESTE       = ' FS-EMP-TESTE
017805       DISPLAY ' FS-EMP-SEPARADOR   = ' FS-EMP-SEPARADOR
017806       DISPLAY ' FS-EMP-FLAG        = ' FS-EMP-FLAG
017807       DISPLAY ' FS-EMP-SEPARADOR   = ' FS-EMP-SEPARADOR
017808       DISPLAY ' FS-EMP-FLAG        = ' FS-EMP-FLAG
017809       DISPLAY ' FS-EMP-LOGRADOURO  = ' WSS-MESSAGE
017810       DISPLAY ' FS-EMP-CIDADE      = ' FS-EMP-CIDADE
017811       DISPLAY ' FS-EMP-UF          = ' FS-EMP-UF
017812       DISPLAY ' FS-EMP-CEP         = ' FS-EMP-CEP
